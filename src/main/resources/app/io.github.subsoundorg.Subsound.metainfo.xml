<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.subsoundorg.Subsound</id>

  <name>Subsound</name>
  <summary>Stream music from your Navidrome Server</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-only</project_license>

  <description>
    <p>
      Subsound is a GTK4/Adwaita music player for Subsonic-compatible streaming servers,
      with Navidrome as the primary target. It lets you browse artists, albums, and playlists
      from your personal music server and plays them back directly or from a local cache.
    </p>
    <p>Features include:</p>
    <ul>
      <li>Browse and play music from Navidrome or any Subsonic-compatible server</li>
      <li>Playlist management</li>
      <li>Starred songs and downloaded songs views</li>
      <li>Offline playback from a local song cache</li>
      <li>Offline first scrobble back to server</li>
      <li>MPRIS media player integration for desktop media controls</li>
      <li>Native GTK4/Adwaita interface designed for GNOME</li>
    </ul>
    <p>For offline mode, remember to first Sync Library.</p>
  </description>

  <developer id="io.github.subsoundorg">
    <name>Eivind Larsen</name>
  </developer>

  <launchable type="desktop-id">io.github.subsoundorg.Subsound.desktop</launchable>

